nextflow_workflow {

    name "DEREPLICATE_SCATTER (stub)"
    script "../subworkflows/local/dereplicate_scatter.nf"
    tag "stub"
    workflow "DEREPLICATE_SCATTER"
    options "-stub"

    test("scatters chunks and gathers one merged representative set") {
        when {
            params {
                derep_process_size = 2
                derep_tool = 'sourmash'
            }
            workflow {
                """
                input[0] = Channel.fromPath("${projectDir}/nextflow/tests/data/genomes/*.fasta")
                """
            }
        }
        then {
            assert workflow.success
            // exactly one merged result, tagged 'merged'
            assert workflow.out.reps.size() == 1
            with(workflow.out.reps.get(0)) {
                assert get(0).id == 'merged'
                def dir = get(1)
                assert path("${dir}/clusters.tsv").exists()
                assert path("${dir}/representatives").exists()
            }
            // a versions file from each chunk task and the merge
            assert workflow.out.versions
        }
    }
}
