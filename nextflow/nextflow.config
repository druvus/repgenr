// RepGenR Nextflow configuration.

plugins {
    // Parameter validation and schema-driven help/summary (nf-core convention).
    id 'nf-schema@2.3.0'
}

params {
    // Where execution reports and published results are written.
    outdir = 'results'

    // Pipeline: 'bacterial' (GTDB) or 'viral' (BV-BRC).
    mode = 'bacterial'

    // Top-level options prepended to every repgenr call (set by container
    // profiles below to run external tools in containers).
    repgenr_opts = ''

    // Per-stage argument strings passed through to the repgenr CLI. The thread
    // count is injected from the task's reserved CPUs, so it is not set here.
    metadata_args  = '-r 232.0 -v bac120 -d rep -l genus -tg francisella'
    vmetadata_args = '-t adenoviridae'
    vgenome_args   = '-tg mastadenovirus'
    // Alignment-free tree builder by default: it scales to large sets, whereas
    // whole-genome aligners (progressivemauve, cactus) are all-pairs and only
    // suit small, closely related sets. Set phylo_args to '--aligner ...' for those.
    phylo_args     = '--treebuilder mashtree'
    tree2tax_args  = '--include-dereplicated'

    // Scatter-gather dereplication. Leave derep_process_size null for a single
    // chunk; set it to scatter large sets across tasks (e.g. 2000). The tool and
    // ANI thresholds are used by each chunk and the merge.
    derep_process_size     = null
    derep_tool             = 'skder'
    derep_primary_ani      = 0.90
    derep_secondary_ani    = 0.99
    derep_aligned_fraction = 0.50

    // Print a usage message and exit (handled in main.nf before validation).
    help = false
}

// Resource labels; tune per environment via profiles. Memory and time scale
// with the retry attempt so a large run that hits an out-of-memory or
// time-limit kill is automatically resubmitted with more headroom.
process {
    errorStrategy = { task.exitStatus in ((130..145) + [104, 247]) ? 'retry' : 'terminate' }
    maxRetries = 2

    withLabel: process_low {
        cpus = 2
        memory = { 4.GB * task.attempt }
        time = { 2.h * task.attempt }
    }
    withLabel: process_medium {
        cpus = 8
        memory = { 16.GB * task.attempt }
        time = { 8.h * task.attempt }
    }
    withLabel: process_high {
        cpus = 32
        memory = { 128.GB * task.attempt }
        time = { 48.h * task.attempt }
    }
}

profiles {
    standard {
        process.executor = 'local'
    }

    slurm {
        process.executor = 'slurm'
        process.queue = 'normal'
    }

    cloud {
        process.executor = 'awsbatch'
    }

    // Container profiles: RepGenR runs each external tool in a container.
    // (RepGenR itself must be available to the process; on HPC the Singularity
    // engine is the clean target. Stacking with Nextflow's own docker engine
    // implies docker-in-docker, so these drive RepGenR's adapter-level backend.)
    docker {
        params.repgenr_opts = '--container docker'
    }

    singularity {
        params.repgenr_opts = '--container singularity'
    }

    wave {
        // RepGenR resolves multi-tool/arm64 images via the Wave CLI.
        params.repgenr_opts = '--container singularity --wave'
    }

    test {
        // Minimal resources for a quick local smoke run on a small target.
        process.executor = 'local'
        process {
            withLabel: process_low    { cpus = 1; memory = 2.GB }
            withLabel: process_medium { cpus = 2; memory = 4.GB }
            withLabel: process_high   { cpus = 2; memory = 4.GB }
        }
        params.metadata_args = '-r 232.0 -v bac120 -d rep -l genus -tg francisella --limit 5'
        params.derep_tool = 'sourmash'
        params.phylo_args = '--treebuilder mashtree'
    }
}

// Execution reports for every run (nf-core convention). Written under
// outdir/pipeline_info with a per-run timestamp so reruns do not overwrite.
// The timestamp is inlined (not a `def`) because the strict config parser
// disallows variable declarations alongside config statements.
timeline {
    enabled = true
    file = "${params.outdir}/pipeline_info/execution_timeline_${new java.util.Date().format('yyyy-MM-dd_HH-mm-ss')}.html"
}
report {
    enabled = true
    file = "${params.outdir}/pipeline_info/execution_report_${new java.util.Date().format('yyyy-MM-dd_HH-mm-ss')}.html"
}
trace {
    enabled = true
    file = "${params.outdir}/pipeline_info/execution_trace_${new java.util.Date().format('yyyy-MM-dd_HH-mm-ss')}.txt"
}
dag {
    enabled = true
    file = "${params.outdir}/pipeline_info/pipeline_dag_${new java.util.Date().format('yyyy-MM-dd_HH-mm-ss')}.html"
}

manifest {
    name            = 'repgenr'
    author          = 'Andreas Sjodin'
    homePage        = 'https://github.com/druvus/repgenr'
    description     = 'Representative-Genome Repositories pipeline'
    mainScript      = 'main.nf'
    nextflowVersion = '>=23.04.0'
    version         = '2.0.0'
    license         = 'MIT'
}
