// RepGenR Nextflow configuration.

params {
    // Shared RepGenR working directory (required).
    workdir = null

    // Per-stage argument strings passed through to the repgenr CLI.
    metadata_args    = '-r 207.0 -v bac120 -d rep -l genus -tg francisella'
    genome_args      = ''
    dereplicate_args = '--tool skder -t 16'
    phylo_args       = '--treebuilder iqtree --aligner progressivemauve'
    tree2tax_args    = '--include-dereplicated'
}

// Resource labels; tune per environment via profiles.
process {
    withLabel: process_low {
        cpus = 2
        memory = 4.GB
        time = '2h'
    }
    withLabel: process_medium {
        cpus = 8
        memory = 16.GB
        time = '8h'
    }
    withLabel: process_high {
        cpus = 32
        memory = 128.GB
        time = '48h'
    }
}

profiles {
    standard {
        process.executor = 'local'
    }

    slurm {
        process.executor = 'slurm'
        process.queue = 'normal'
    }

    cloud {
        process.executor = 'awsbatch'
    }

    test {
        // Minimal resources for a quick local smoke run on a small target.
        process.executor = 'local'
        process {
            withLabel: process_low    { cpus = 1; memory = 2.GB }
            withLabel: process_medium { cpus = 2; memory = 4.GB }
            withLabel: process_high   { cpus = 2; memory = 4.GB }
        }
        params.metadata_args = '-r 207.0 -v bac120 -d rep -l genus -tg francisella --limit 5'
        params.dereplicate_args = '--tool skder -t 2'
        params.phylo_args = '--treebuilder mashtree'
    }
}

manifest {
    name = 'repgenr'
    description = 'Representative-Genome Repositories pipeline'
    mainScript = 'main.nf'
    nextflowVersion = '>=23.04.0'
}
