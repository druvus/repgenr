config {
    // nf-test for the RepGenR Nextflow layer. Tests live next to the pipeline,
    // run under the 'test' profile, and use stub blocks so no external tools or
    // network are required -- the assertions cover channel wiring and contracts.
    testsDir "nextflow/tests"
    workDir ".nf-test"
    configFile "nextflow/nextflow.config"
    profile "test"
}
